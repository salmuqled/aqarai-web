rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ============================================================
        Helpers
    ============================================================ */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isFalseOrMissing(field) {
      return !(field in request.resource.data)
        || request.resource.data[field] == false;
    }

    function propertyPublicDiscovery(data) {
      return data.approved == true
        && (!('hiddenFromPublic' in data) || data.hiddenFromPublic == false)
        && (!('status' in data)
            || data.status == ''
            || data.status == 'active'
            || data.status == 'approved');
    }

    /* ============================================================
        Properties (العقارات)
    ============================================================ */

    match /properties/{propertyId} {

      // 👀 القراءة:
      // - العامة: معتمد + غير مخفي + حالة نشطة (أو approved قديمة)
      // - المالك والأدمن: دائماً
      allow read: if
        propertyPublicDiscovery(resource.data)
        ||
        (isSignedIn() && resource.data.ownerId == request.auth.uid)
        ||
        isAdmin();

      // ➕ الإنشاء:
      // - أي مستخدم مسجّل
      // - ممنوع تمرير approved=true
      // - ممنوع تمرير imagesApproved=true
      allow create: if isSignedIn()
        && isFalseOrMissing('approved')
        && isFalseOrMissing('imagesApproved');

      // ✏️ التعديل:
      // - الأدمن
      // - أو صاحب الإعلان فقط
      allow update: if
        isAdmin()
        ||
        (
          isSignedIn()
          && resource.data.ownerId == request.auth.uid
        );

      // ❌ الحذف:
      // - الأدمن
      // - أو صاحب الإعلان فقط
      allow delete: if
        isAdmin()
        ||
        (
          isSignedIn()
          && resource.data.ownerId == request.auth.uid
        );
    }

    /* ============================================================
        Closure requests — Phase 1 (إغلاق إعلانات عادية فقط)
    ============================================================ */

    match /closure_requests/{requestId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.propertyId is string
        && request.resource.data.status == 'pending'
        && get(/databases/$(database)/documents/properties/$(request.resource.data.propertyId)).data.ownerId == request.auth.uid;

      allow update: if isAdmin();

      allow delete: if false;
    }

    /* ============================================================
        Property views (attribution: AI / search / featured / direct)
    ============================================================ */

    function propertyViewLeadSourceOk() {
      return request.resource.data.leadSource in ['ai_chat', 'search', 'featured', 'direct'];
    }

    /// Listing owner may read all views on that property (multi-view attribution on closure).
    function propertyViewReadableByListingOwner() {
      return isSignedIn()
        && resource.data.propertyId is string
        && exists(/databases/$(database)/documents/properties/$(resource.data.propertyId))
        && get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.ownerId == request.auth.uid;
    }

    match /property_views/{docId} {
      // Append-only analytics; readers: admin, viewer (own userId), or listing owner (attribution).
      allow create: if propertyViewLeadSourceOk()
        && request.resource.data.propertyId is string
        && request.resource.data.keys().hasAll(['propertyId', 'leadSource', 'viewedAt'])
        && (
          (
            isSignedIn()
            && request.resource.data.userId == request.auth.uid
            && !('anonymousId' in request.resource.data)
          )
          ||
          (
            request.auth == null
            && request.resource.data.anonymousId is string
            && request.resource.data.anonymousId.size() >= 16
            && !('userId' in request.resource.data)
          )
        );

      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid)
        || propertyViewReadableByListingOwner();

      allow update, delete: if false;
    }

    /* ============================================================
        Deals (صفقات معتمدة — تقارير)
    ============================================================ */

    match /deals/{dealId} {
      allow read, write: if isAdmin();
    }

    /* ============================================================
        Analytics (تجميعات الأعمال — قراءة/كتابة أدمن فقط)
    ============================================================ */

    match /analytics/{docId} {
      allow read, write: if isAdmin();
    }

    /* ============================================================
        Admin settings (global — hybrid marketing, etc.)
    ============================================================ */

    match /admin_settings/global {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    /* ============================================================
        System alerts (scheduled job creates — admin read / mark read)
    ============================================================ */

    match /system_alerts/{alertId} {
      allow read: if isAdmin();
      allow create, delete: if false;
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['read', 'readAt']);
    }

    match /admin_caption_selections/{docId} {
      allow read, write: if isAdmin();
    }

    match /caption_usage_logs/{docId} {
      allow read, write: if isAdmin();
    }

    match /caption_clicks/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.captionId is string
        && request.resource.data.propertyId is string
        && (!('userId' in request.resource.data)
            || request.resource.data.userId == request.auth.uid);
    }

    match /caption_learning/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    /* ============================================================
        Auto decision logs (توصيات التسويق — أدمن فقط)
    ============================================================ */

    match /auto_decision_logs/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.suggestedCaptionId is string
        && request.resource.data.chosenCaptionId is string
        && request.resource.data.override is bool
        && request.resource.data.suggestedAudience is string
        && request.resource.data.chosenAudience is string
        && request.resource.data.suggestedTime is int
        && request.resource.data.chosenTime is int
        && request.resource.data.confidence is number
        && request.resource.data.expectedCtr is number
        && request.resource.data.adminUid is string
        && request.resource.data.decisionLevel is string
        && request.resource.data.autoExecuted is bool;
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['autoExecuted']);
      allow delete: if false;
    }

    match /auto_decision_learning/{docId} {
      allow read, create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    /* ============================================================
        Notification logs (FCM campaigns — كتابة عبر Functions فقط)
    ============================================================ */

    match /notification_logs/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    /* ============================================================
        Notification learning (أوزان عوامل التنبؤ — كتابة عبر Functions فقط)
    ============================================================ */

    match /notification_learning/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    /* ============================================================
        Notification clicks (فتح من الإشعار — إنشاء من مستخدم مسجّل)
    ============================================================ */

    function notificationClickKeysOk() {
      return request.resource.data.keys().hasOnly([
        'userId',
        'openedAt',
        'clickedAt',
        'notificationId',
        'notificationTitle',
        'variantId'
      ]);
    }

    match /notification_clicks/{docId} {
      allow create: if isSignedIn()
        && notificationClickKeysOk()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'openedAt', 'clickedAt'])
        && (!('notificationId' in request.resource.data)
            || (request.resource.data.notificationId is string
                && request.resource.data.notificationId.size() <= 200))
        && (!('notificationTitle' in request.resource.data)
            || (request.resource.data.notificationTitle is string
                && request.resource.data.notificationTitle.size() <= 400))
        && (!('variantId' in request.resource.data)
            || (request.resource.data.variantId is string
                && request.resource.data.variantId.size() <= 64));
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    /* ============================================================
        Wanted Requests (مطلوب)
    ============================================================ */

    match /wanted_requests/{docId} {

      // 👀 القراءة:
      allow read: if resource.data.approved == true || isAdmin();

      // ➕ الإضافة:
      allow create: if isSignedIn()
        && isFalseOrMissing('approved');

      // ✏️ / ❌:
      allow update, delete: if isAdmin();
    }

    /* ============================================================
        Valuations (التقييمات)
    ============================================================ */

    match /valuations/{docId} {

      // ➕ إنشاء:
      allow create: if isSignedIn();

      // 👀 / ✏️ / ❌:
      allow read, update, delete: if isAdmin();
    }

    /* ============================================================
        Admin Inbox (تنبيهات الأدمن)
    ============================================================ */

    match /admin_inbox/{docId} {
      allow read, write: if isAdmin();
    }

    /* ============================================================
        Match Logs (سجلات الذكاء الاصطناعي)
    ============================================================ */

    match /match_logs/{docId} {
      allow read, write: if isAdmin();
    }

    /* ============================================================
        Users (ملف المستخدم — حفظ fcmToken للإشعارات)
    ============================================================ */

    /* ============================================================
        User activity (وقت/جمهور الإشعارات — تحديث ذاتي فقط)
    ============================================================ */

    match /user_activity/{uid} {
      allow read: if isAdmin();
      allow create, update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.userId == uid
        && request.resource.data.lastActiveHour is int
        && request.resource.data.lastActiveDay is int
        && request.resource.data.lastSeenAt is timestamp
        && request.resource.data.keys().hasAll([
          'userId',
          'lastSeenAt',
          'lastActiveHour',
          'lastActiveDay'
        ]);
      allow delete: if false;
    }

    /* ============================================================
        Scheduled notification jobs (أدمن فقط — لا إرسال تلقائي من العميل)
    ============================================================ */

    match /scheduled_notification_jobs/{jobId} {
      allow read, create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    /* ============================================================
        Activity stats (تجميع سيرفري — قراءة أدمن فقط)
    ============================================================ */

    match /activity_stats/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    function userCreateNotBanned() {
      let r = request.resource.data;
      return !(('isBanned' in r && r.isBanned == true)
        || ('status' in r && r.status == 'banned'));
    }

    // Non-admin self-updates: cannot change ban state or moderation metadata.
    function selfUserModerationFieldsOk() {
      let r = request.resource.data;
      let o = resource.data;
      let bannedBefore = ('isBanned' in o && o.isBanned == true)
        || ('status' in o && o.status == 'banned');
      let bannedAfter = ('isBanned' in r && r.isBanned == true)
        || ('status' in r && r.status == 'banned');
      return bannedBefore == bannedAfter
        && (('bannedAt' in r) == ('bannedAt' in o))
        && (!('bannedAt' in r && 'bannedAt' in o) || r.bannedAt == o.bannedAt)
        && (('bannedBy' in r) == ('bannedBy' in o))
        && (!('bannedBy' in r && 'bannedBy' in o) || r.bannedBy == o.bannedBy);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && userCreateNotBanned();
      allow update: if isAdmin()
        || (isSignedIn()
            && request.auth.uid == userId
            && selfUserModerationFieldsOk());
      allow delete: if false;
    }

    /* ============================================================
        Support tickets (شكاوى وتواصل — إنشاء من المستخدم، إدارة من الأدمن)
    ============================================================ */

    match /support_tickets/{ticketId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'open'
        && request.resource.data.subject is string
        && request.resource.data.subject.size() > 0
        && request.resource.data.subject.size() <= 500
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 8000
        && request.resource.data.category is string
        && request.resource.data.userName is string
        && request.resource.data.userName.size() <= 200
        && request.resource.data.userPhone is string
        && request.resource.data.userPhone.size() <= 80;

      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);

      allow update, delete: if isAdmin();
    }

    match /users/{userId}/favorites/{favoriteId} {
      allow read, create, update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    /* ============================================================
        Buyer Interests (اهتمامات المشتري — Demand Engine)
    ============================================================ */

    match /buyer_interests/{docId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll([
          'userId',
          'areaCode',
          'type'
        ])
        && request.resource.data.keys().hasOnly([
          'userId',
          'areaCode',
          'type',
          'serviceType',
          'budget',
          'createdAt',
          'source'
        ]);
      allow read: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    /* ============================================================
        Official auctions (Kuwait — MoC; admin + controlled participant writes)
        Catalog: non-draft auctions + public_lots readable by anyone.
        Full lots: admin read only (mirrored to public_lots by Cloud Function).
    ============================================================ */

    match /auctions/{auctionId} {
      allow read: if isAdmin() || resource.data.status != 'draft';
      allow create, update, delete: if isAdmin();
    }

    /* Authoritative lot data (admin read/write). Clients browse public_lots. */
    match /lots/{lotId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /* Safe catalog mirror of lots — synced by Cloud Function only. */
    match /public_lots/{lotId} {
      allow read: if true;
      allow write: if false;
    }

    match /auction_participants/{docId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.auctionId is string
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    match /lot_permissions/{docId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /deposits/{docId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      // One document per user per lot: ID must be `{uid}_{lotId}` (same as Cloud Function).
      allow create: if isSignedIn()
        && docId == request.auth.uid + '_' + request.resource.data.lotId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.paymentStatus == 'pending'
        && request.resource.data.auctionId is string
        && request.resource.data.lotId is string;
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /bids/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /auction_logs/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    /* ============================================================
        Interested Leads (تفاصيل المهتم — ضغط "أنا مهتم")
    ============================================================ */

    match /interested_leads/{docId} {

      // ➕ أي شخص يضيف (حتى مجهول) عند الضغط "أنا مهتم"
      allow create: if true;

      // 👀 الأدمن فقط يقرأ قائمة المهتمين
      allow read: if isAdmin();

      // ✏️ لا تعديل
      allow update: if false;

      // ❌ الأدمن فقط يحذف بعد ما يخلص من التفاصيل
      allow delete: if isAdmin();
    }
  }
}
