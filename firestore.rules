rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ============================================================
        Helpers
    ============================================================ */

    function isSignedIn() {
      return request.auth != null;
    }

    /// Custom claim `admin` — boolean true (preferred) or legacy string "true".
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true
        || request.auth.token.admin == 'true'
      );
    }

    function isFalseOrMissing(field) {
      return !(field in request.resource.data)
        || request.resource.data[field] == false;
    }

    /// Public read: chalet by `type` (primary) or legacy `listingCategory == chalet`;
    /// normal marketplace: `listingCategory == normal` && isActive.
    /// Signed-in user owns the property document (chalet blocks, etc.).
    function propertyOwnedByAuth(propertyId) {
      return isSignedIn()
        && propertyId is string
        && exists(/databases/$(database)/documents/properties/$(propertyId))
        && get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
    }

    function propertyPublicDiscovery(data) {
      return data.approved == true
        && (!('status' in data) || data.status != 'pending_upload')
        && 'hiddenFromPublic' in data
        && data.hiddenFromPublic == false
        && (
             ('type' in data && data.type == 'chalet')
          || ('listingCategory' in data && data.listingCategory == 'chalet')
          || (
               'listingCategory' in data
            && data.listingCategory == 'normal'
            && data.isActive == true )
        );
    }

    /// Writes: if `type == chalet`, `listingCategory` must be `chalet`.
    function propertyChaletTypeCategoryAligned(data) {
      return !('type' in data && data.type == 'chalet')
          || ('listingCategory' in data && data.listingCategory == 'chalet');
    }

    /* ============================================================
        Properties (العقارات)
    ============================================================ */

    match /properties/{propertyId} {

      // 👀 القراءة:
      // - العامة: approved + (type==chalet أو listingCategory chalet legacy) أو normal+isActive؛ hiddenFromPublic == false
      // - المالك والأدمن: دائماً
      allow read: if
        propertyPublicDiscovery(resource.data)
        ||
        (isSignedIn() && resource.data.ownerId == request.auth.uid)
        ||
        isAdmin();

      // ➕ الإنشاء:
      // - أي مستخدم مسجّل
      // - ممنوع تمرير approved=true
      // - ممنوع تمرير imagesApproved=true
      allow create: if isSignedIn()
        && isFalseOrMissing('approved')
        && isFalseOrMissing('imagesApproved')
        && request.resource.data.listingCategory in ['normal', 'chalet']
        && propertyChaletTypeCategoryAligned(request.resource.data)
        && request.resource.data.hiddenFromPublic == false
        && request.resource.data.status == 'pending_upload'
        && request.resource.data.hasImage == false;

      // ✏️ التعديل:
      // - الأدمن
      // - أو صاحب الإعلان فقط
      function ownerPropertyContentUpdateAllowed() {
        // Owners may edit only user-authored listing fields (NO moderation / featuring / payments).
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          // Basic content
          'title',
          'description',
          'price',
          'type',
          'serviceType',
          'listingCategory',
          'chaletMode',

          // Location (display + search codes)
          'governorateAr',
          'governorateEn',
          'areaAr',
          'areaEn',
          'governorateCode',
          'areaCode',

          // Details
          'roomCount',
          'masterRoomCount',
          'bathroomCount',
          'parkingCount',
          'size',

          // Amenities
          'hasElevator',
          'hasCentralAC',
          'hasSplitAC',
          'hasMaidRoom',
          'hasDriverRoom',
          'hasLaundryRoom',
          'hasGarden',
          'hasPoolIndoor',
          'hasPoolOutdoor',
          'isBeachfront',

          // Media
          'images',
          'thumbnails',
          'coverUrl',
          'videoUrl',

          // Housekeeping
          'updatedAt',
          'id'
        ]);
      }

      // Owner finished Storage upload: pending_upload + hasImage:false → active + image URLs.
      function ownerCompletePendingUpload() {
        return isSignedIn()
          && resource.data.ownerId == request.auth.uid
          && resource.data.status == 'pending_upload'
          && (!('hasImage' in resource.data) || resource.data.hasImage == false)
          && request.resource.data.status == 'active'
          && request.resource.data.hasImage == true
          && request.resource.data.images is list
          && request.resource.data.images.size() > 0
          && request.resource.data.thumbnails is list
          && request.resource.data.thumbnails.size() == request.resource.data.images.size()
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['images', 'thumbnails', 'hasImage', 'status', 'updatedAt', 'id']);
      }

      function ownerPropertyClosureUpdateAllowed() {
        // Owner closure request flow updates visibility + status to a *pending* confirmation.
        // This keeps sales/closure UX working while still blocking arbitrary status edits.
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'hiddenFromPublic',
          'isActive',
          'status',
          'closeRequestSubmitted',
          'closeRequestType',
          'closeRequestedAt',
          'closeRequestedBy',
          'updatedAt'
        ])
        && request.resource.data.hiddenFromPublic == true
        && request.resource.data.isActive == false
        && request.resource.data.closeRequestSubmitted == true
        && request.resource.data.closeRequestedBy == request.auth.uid;
      }

      // If `type` / `listingCategory` change, resulting doc must satisfy chalet alignment (legacy mismatch OK until edited).
      function propertyTypeOrCategoryChanged() {
        return request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['type', 'listingCategory']);
      }

      allow update: if (
          !propertyTypeOrCategoryChanged()
          || propertyChaletTypeCategoryAligned(request.resource.data)
        )
        && (
          isAdmin()
          || (
            isSignedIn()
            && resource.data.ownerId == request.auth.uid
            && (
              ownerPropertyContentUpdateAllowed()
              || ownerPropertyClosureUpdateAllowed()
              || ownerCompletePendingUpload()
            )
          )
        );

      // ❌ الحذف:
      // - الأدمن
      // - أو صاحب الإعلان فقط
      allow delete: if
        isAdmin()
        ||
        (
          isSignedIn()
          && resource.data.ownerId == request.auth.uid
        );
    }

    /* ============================================================
        Chalet bookings (writes only via Cloud Functions / Admin SDK)
    ============================================================ */

    match /bookings/{bookingId} {
      allow read: if isSignedIn()
        && (
          resource.data.clientId == request.auth.uid
          || resource.data.ownerId == request.auth.uid
          || isAdmin()
        );

      allow create, update, delete: if false;
    }

    /* ============================================================
        External blocks (manual / external bookings)
    ============================================================ */

    match /blocked_dates/{blockId} {
      // Reads are OR'd across separate `allow read` clauses (better query / rules evaluation).
      allow read: if isAdmin();

      // Listing owner: any block row for a property they own (owner calendar + availability tools).
      allow read: if resource.data.propertyId is string
        && propertyOwnedByAuth(resource.data.propertyId);

      // Owner-created rows: creator can read (covers edge cases; create still requires owning the listing).
      allow read: if isSignedIn()
        && resource.data.propertyId is string
        && resource.data.source == 'owner'
        && resource.data.ownerId == request.auth.uid;

      // Public read for guests when the listing is discoverable.
      allow read: if resource.data.propertyId is string
        && exists(/databases/$(database)/documents/properties/$(resource.data.propertyId))
        && propertyPublicDiscovery(
          get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data
        );

      // Owner: create manual blocks (same overlap semantics as admin blocks).
      allow create: if isAdmin() || (
        isSignedIn()
        && request.resource.data.keys().hasOnly(['propertyId', 'startDate', 'endDate', 'source', 'ownerId'])
        && request.resource.data.propertyId is string
        && propertyOwnedByAuth(request.resource.data.propertyId)
        && request.resource.data.startDate is timestamp
        && request.resource.data.endDate is timestamp
        && request.resource.data.startDate < request.resource.data.endDate
        && request.resource.data.source == 'owner'
        && request.resource.data.ownerId == request.auth.uid
      );

      allow update: if isAdmin();

      // Owner may remove only their owner-sourced blocks; admin any.
      allow delete: if isAdmin() || (
        isSignedIn()
        && resource.data.propertyId is string
        && propertyOwnedByAuth(resource.data.propertyId)
        && resource.data.source == 'owner'
        && resource.data.ownerId == request.auth.uid
      );
    }

    /* ============================================================
        Chalet booking ledger (Cloud Functions create; admin payout via callable)
    ============================================================ */

    match /transactions/{txId} {
      allow read: if isSignedIn()
        && (
          resource.data.ownerId == request.auth.uid
          || resource.data.clientId == request.auth.uid
          || isAdmin()
        );

      allow create, update, delete: if false;
    }

    /* ============================================================
        Closure requests — Phase 1 (إغلاق إعلانات عادية فقط)
    ============================================================ */

    match /closure_requests/{requestId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.propertyId is string
        && request.resource.data.status == 'pending'
        && get(/databases/$(database)/documents/properties/$(request.resource.data.propertyId)).data.ownerId == request.auth.uid;

      allow update: if isAdmin();

      allow delete: if false;
    }

    /* ============================================================
        Property views (attribution: AI / search / featured / direct)
    ============================================================ */

    function propertyViewLeadSourceOk() {
      return request.resource.data.leadSource in ['ai_chat', 'search', 'featured', 'direct'];
    }

    /// Listing owner may read all views on that property (multi-view attribution on closure).
    function propertyViewReadableByListingOwner() {
      return isSignedIn()
        && resource.data.propertyId is string
        && exists(/databases/$(database)/documents/properties/$(resource.data.propertyId))
        && get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.ownerId == request.auth.uid;
    }

    match /property_views/{docId} {
      // Append-only analytics; readers: admin, viewer (own userId), or listing owner (attribution).
      allow create: if propertyViewLeadSourceOk()
        && request.resource.data.propertyId is string
        && request.resource.data.keys().hasAll(['propertyId', 'leadSource', 'viewedAt'])
        && (
          (
            isSignedIn()
            && request.resource.data.userId == request.auth.uid
            && !('anonymousId' in request.resource.data)
          )
          ||
          (
            request.auth == null
            && request.resource.data.anonymousId is string
            && request.resource.data.anonymousId.size() >= 16
            && !('userId' in request.resource.data)
          )
        );

      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid)
        || propertyViewReadableByListingOwner();

      allow update, delete: if false;
    }

    /* ============================================================
        Deals (صفقات معتمدة — تقارير + اهتمام مستخدم بعقار)
    ============================================================ */

    /// Deal must exist and be finalized before a commission row can be [confirmed]
    /// (matches server-side ledger sync in Cloud Functions).
    function dealExistsAndCommissionFinalized(dealId) {
      return dealId is string
        && dealId.size() > 0
        && exists(/databases/$(database)/documents/deals/$(dealId))
        && get(/databases/$(database)/documents/deals/$(dealId)).data.dealStatus in ['signed', 'closed'];
    }

    /// Admin cannot edit server-owned commission mirror fields (Functions only).
    function dealServerFinancialMirrorKeys() {
      return [
        'commissionPaidTotalKwd',
        'commissionPaymentStatus',
        'commissionLastPaymentAt',
        'commissionOverpaidKwd',
        'isCommissionPaid',
        'commissionPaidAt'
      ];
    }

    function dealAdminUpdateDoesNotTouchServerFinancialMirrors() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(dealServerFinancialMirrorKeys());
    }

    function interestDealCreateValid(dealId) {
      let r = request.resource.data;
      let uid = request.auth.uid;
      let idProp = r.propertyId is string
        && r.propertyId.size() > 0
        && dealId == ('int_' + uid + '_' + r.propertyId);
      let idWant = r.propertyId == ''
        && r.wantedId is string
        && r.wantedId.size() > 0
        && dealId == ('int_' + uid + '_w_' + r.wantedId);
      return (idProp || idWant)
        && r.clientId == uid
        && r.leadSource == 'interested_button'
        && r.leadCreatedAt is timestamp
        && r.status == 'new'
        && r.dealStatus == 'new'
        && r.clientPhone is string
        && r.clientPhone.size() >= 3
        && r.clientPhone.size() <= 40
        && (!('clientEmail' in r) || r.clientEmail is string)
        && r.finalPrice == 0
        && r.commission == 0
        && r.commissionCalculated == false
        && r.bookingAmount == 0
        && r.isBooked == false
        && r.isSigned == false
        && r.isCommissionPaid == false
        && r.serviceType is string
        && (r.serviceType == 'sale' || r.serviceType == 'rent' || r.serviceType == 'exchange')
        && r.propertyTitle is string
        && r.propertyTitle.size() <= 500
        && (r.propertyPrice is int || r.propertyPrice is float);
    }

    match /deals/{dealId} {
      allow read: if isAdmin()
        || (isSignedIn()
            && resource.data.clientId == request.auth.uid);

      allow create: if isAdmin()
        || (isSignedIn() && interestDealCreateValid(dealId));

      allow update: if isAdmin() && dealAdminUpdateDoesNotTouchServerFinancialMirrors();

      allow delete: if isAdmin();
    }

    /* ============================================================
        Analytics (تجميعات الأعمال — قراءة/كتابة أدمن فقط)
    ============================================================ */

    match /analytics/{docId} {
      allow read, write: if isAdmin();
    }

    /* AI suggestions config change log (append-only for clients). */
    match /ai_config_history/{entryId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    /* Property image upload telemetry (append-only; owner writes own rows). */
    match /upload_events/{eventId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.keys()
             .hasOnly(['propertyId', 'userId', 'eventType', 'timestamp'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.propertyId is string
        && request.resource.data.eventType is string
        && request.resource.data.eventType in [
          'image_upload_started',
          'image_upload_failed',
          'image_upload_retry',
          'image_upload_success'
        ];
      allow update, delete: if false;
    }

    /* AI chat analytics stream (append-only; signed-in, owner-scoped writes).
       Events: suggestion_impression / suggestion_click / suggestion_result /
               search_executed / search_empty
       Admin-only read; no update/delete to preserve BI integrity. */
    match /analytics_events/{eventId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
             'eventType', 'userId', 'data',
             'createdAt', 'clientEpochMs', 'serverReceivedAt'
           ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.eventType is string
        && request.resource.data.eventType in [
             'suggestion_impression',
             'suggestion_click',
             'suggestion_result',
             'search_executed',
             'search_empty'
           ]
        && request.resource.data.data is map;
      allow update, delete: if false;
    }

    /* Featured listing suggestion funnel (owner-only analytics writes). */
    match /feature_suggestion_events/{eventId} {
      allow read: if isAdmin();
      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.propertyId is string
        && request.resource.data.suggestionType is string
        && request.resource.data.event is string
        && request.resource.data.event in [
          'suggestion_shown',
          'suggestion_clicked',
          'ai_conversion_success'
        ];
      allow delete: if false;
    }

    /* ============================================================
        Admin settings (global — hybrid marketing, etc.)
    ============================================================ */

    match /admin_settings/global {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    /* ============================================================
        System alerts (scheduled job creates — admin read / mark read)
    ============================================================ */

    match /system_alerts/{alertId} {
      allow read: if isAdmin();

      function uploadIssueAlertCreateValid() {
        let d = request.resource.data;
        return d.type == 'upload_issue'
          && d.severity == 'warning'
          && d.read == false
          && d.titleEn is string
          && d.titleAr is string
          && d.messageEn is string
          && d.messageAr is string
          && d.metrics is map
          && d.keys().hasOnly([
            'type', 'severity', 'titleEn', 'titleAr', 'messageEn', 'messageAr',
            'read', 'metrics', 'timestamp', 'createdAt', 'updatedAt'
          ]);
      }

      function clientErrorAlertCreateValid() {
        let d = request.resource.data;
        let m = d.metrics;
        return d.type == 'client_error'
          && d.severity == 'warning'
          && d.read == false
          && d.titleEn is string
          && d.titleAr is string
          && d.messageEn is string
          && d.messageAr is string
          && m is map
          && m.keys().hasOnly(['fingerprint', 'exceptionType', 'detail'])
          && m.fingerprint is string
          && m.exceptionType is string
          && m.detail is string
          && m.fingerprint.size() <= 200
          && m.exceptionType.size() <= 200
          && m.detail.size() <= 1500
          && d.keys().hasOnly([
            'type', 'severity', 'titleEn', 'titleAr', 'messageEn', 'messageAr',
            'read', 'metrics', 'timestamp', 'createdAt', 'updatedAt'
          ]);
      }

      allow create: if isAdmin() && (uploadIssueAlertCreateValid() || clientErrorAlertCreateValid());
      allow delete: if false;
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['read', 'readAt']);
    }

    /* Server-only dedupe log for deal follow-up FCM (Cloud Functions Admin SDK). */
    match /followup_notifications/{id} {
      allow read, write: if false;
    }

    match /admin_caption_selections/{docId} {
      allow read, write: if isAdmin();
    }

    match /caption_usage_logs/{docId} {
      allow read, write: if isAdmin();
    }

    match /caption_clicks/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.captionId is string
        && request.resource.data.propertyId is string
        && (!('userId' in request.resource.data)
            || request.resource.data.userId == request.auth.uid);
    }

    match /caption_learning/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    /* ============================================================
        Auto decision logs (توصيات التسويق — أدمن فقط)
    ============================================================ */

    match /auto_decision_logs/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.suggestedCaptionId is string
        && request.resource.data.chosenCaptionId is string
        && request.resource.data.override is bool
        && request.resource.data.suggestedAudience is string
        && request.resource.data.chosenAudience is string
        && request.resource.data.suggestedTime is int
        && request.resource.data.chosenTime is int
        && request.resource.data.confidence is number
        && request.resource.data.expectedCtr is number
        && request.resource.data.adminUid is string
        && request.resource.data.decisionLevel is string
        && request.resource.data.autoExecuted is bool;
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['autoExecuted']);
      allow delete: if false;
    }

    match /auto_decision_learning/{docId} {
      allow read, create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    /* ============================================================
        Notification logs (FCM campaigns — كتابة عبر Functions فقط)
    ============================================================ */

    match /notification_logs/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    /* ============================================================
        Notification learning (أوزان عوامل التنبؤ — كتابة عبر Functions فقط)
    ============================================================ */

    match /notification_learning/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    /* ============================================================
        Notification clicks (فتح من الإشعار — إنشاء من مستخدم مسجّل)
    ============================================================ */

    function notificationClickKeysOk() {
      return request.resource.data.keys().hasOnly([
        'userId',
        'openedAt',
        'clickedAt',
        'notificationId',
        'notificationTitle',
        'variantId'
      ]);
    }

    match /notification_clicks/{docId} {
      allow create: if isSignedIn()
        && notificationClickKeysOk()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'openedAt', 'clickedAt'])
        && (!('notificationId' in request.resource.data)
            || (request.resource.data.notificationId is string
                && request.resource.data.notificationId.size() <= 200))
        && (!('notificationTitle' in request.resource.data)
            || (request.resource.data.notificationTitle is string
                && request.resource.data.notificationTitle.size() <= 400))
        && (!('variantId' in request.resource.data)
            || (request.resource.data.variantId is string
                && request.resource.data.variantId.size() <= 64));
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    /* ============================================================
        Wanted Requests (مطلوب)
    ============================================================ */

    match /wanted_requests/{docId} {

      // 👀 القراءة:
      // - عام: فقط المعتمد.
      // - أدمن: كل شيء.
      // - المالك: إعلاناته الخاصة (حتى قبل الاعتماد) — يدعم صفحة "إعلاناتي".
      allow read: if resource.data.approved == true
        || isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);

      // ➕ الإضافة:
      allow create: if isSignedIn()
        && isFalseOrMissing('approved');

      // ✏️ / ❌:
      allow update, delete: if isAdmin();
    }

    /* ============================================================
        Valuations (التقييمات)
    ============================================================ */

    match /valuations/{docId} {

      // ➕ إنشاء:
      allow create: if isSignedIn();

      // 👀 القراءة:
      // - أدمن: كل التقييمات.
      // - المالك: تقييماته الخاصة — يدعم صفحة "إعلاناتي".
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);

      // ✏️ / ❌:
      allow update, delete: if isAdmin();
    }

    /* ============================================================
        Exception logs (مراقبة الأعطال — إنشاء من Cloud Functions فقط)
    ============================================================ */

    match /exception_logs/{logId} {
      allow read: if isAdmin();
      allow create, delete: if false;
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['resolved', 'resolvedAt'])
        && request.resource.data.resolved is bool
        && (!('resolvedAt' in request.resource.data)
          || request.resource.data.resolvedAt == null
          || request.resource.data.resolvedAt is timestamp);
    }

    /* ============================================================
        Admin Inbox (تنبيهات الأدمن)
    ============================================================ */

    match /admin_inbox/{docId} {
      allow read, write: if isAdmin();
    }

    /* ============================================================
        Match Logs (سجلات الذكاء الاصطناعي)
    ============================================================ */

    match /match_logs/{docId} {
      allow read, write: if isAdmin();
    }

    /* ============================================================
        Users (ملف المستخدم — حفظ fcmToken للإشعارات)
    ============================================================ */

    /* ============================================================
        User activity (وقت/جمهور الإشعارات — تحديث ذاتي فقط)
    ============================================================ */

    match /user_activity/{uid} {
      allow read: if isAdmin();
      allow create, update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.userId == uid
        && request.resource.data.lastActiveHour is int
        && request.resource.data.lastActiveDay is int
        && request.resource.data.lastSeenAt is timestamp
        && request.resource.data.keys().hasAll([
          'userId',
          'lastSeenAt',
          'lastActiveHour',
          'lastActiveDay'
        ]);
      allow delete: if false;
    }

    /* ============================================================
        Scheduled notification jobs (أدمن فقط — لا إرسال تلقائي من العميل)
    ============================================================ */

    match /scheduled_notification_jobs/{jobId} {
      allow read, create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    /* ============================================================
        Activity stats (تجميع سيرفري — قراءة أدمن فقط)
    ============================================================ */

    match /activity_stats/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    function userCreateNotBanned() {
      let r = request.resource.data;
      return !(('isBanned' in r && r.isBanned == true)
        || ('status' in r && r.status == 'banned'));
    }

    // Non-admin self-updates: cannot change ban state or moderation metadata.
    function selfUserModerationFieldsOk() {
      let r = request.resource.data;
      let o = resource.data;
      let bannedBefore = ('isBanned' in o && o.isBanned == true)
        || ('status' in o && o.status == 'banned');
      let bannedAfter = ('isBanned' in r && r.isBanned == true)
        || ('status' in r && r.status == 'banned');
      return bannedBefore == bannedAfter
        && (('bannedAt' in r) == ('bannedAt' in o))
        && (!('bannedAt' in r && 'bannedAt' in o) || r.bannedAt == o.bannedAt)
        && (('bannedBy' in r) == ('bannedBy' in o))
        && (!('bannedBy' in r && 'bannedBy' in o) || r.bannedBy == o.bannedBy);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && userCreateNotBanned();
      allow update: if isAdmin()
        || (isSignedIn()
            && request.auth.uid == userId
            && selfUserModerationFieldsOk());
      allow delete: if false;
    }

    /* ============================================================
        FCM inbox (Cloud Functions write; user marks read only)
    ============================================================ */

    match /notifications/{notificationId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow create, delete: if false;

      /* User may only toggle read/hide; all inbox content & priority remain server-owned. */
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.notificationType == resource.data.notificationType
        && request.resource.data.title == resource.data.title
        && request.resource.data.body == resource.data.body
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.version == resource.data.version
        && request.resource.data.data == resource.data.data
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['isRead', 'isHidden'])
        && (!('priority' in resource.data) ||
          request.resource.data.priority == resource.data.priority)
        && (!('isRead' in resource.data) || resource.data.isRead == false
          || request.resource.data.isRead == true)
        && (!('isHidden' in request.resource.data)
          || request.resource.data.isHidden is bool);
    }

    /* ============================================================
        Support tickets (شكاوى وتواصل — إنشاء من المستخدم، إدارة من الأدمن)
    ============================================================ */

    match /support_tickets/{ticketId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'open'
        && request.resource.data.subject is string
        && request.resource.data.subject.size() > 0
        && request.resource.data.subject.size() <= 500
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 8000
        && request.resource.data.category is string
        && request.resource.data.userName is string
        && request.resource.data.userName.size() <= 200
        && request.resource.data.userPhone is string
        && request.resource.data.userPhone.size() <= 80;

      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);

      allow update, delete: if isAdmin();
    }

    match /users/{userId}/favorites/{favoriteId} {
      allow read, create, update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    /* ============================================================
        Buyer Interests (اهتمامات المشتري — Demand Engine)
    ============================================================ */

    match /buyer_interests/{docId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll([
          'userId',
          'areaCode',
          'type'
        ])
        && request.resource.data.keys().hasOnly([
          'userId',
          'areaCode',
          'type',
          'serviceType',
          'budget',
          'createdAt',
          'source'
        ]);
      allow read: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    /* ============================================================
        Official auctions (Kuwait — MoC; admin + controlled participant writes)
        Catalog: non-draft auctions + public_lots readable by anyone.
        Full lots: admin read only (mirrored to public_lots by Cloud Function).
    ============================================================ */

    match /auctions/{auctionId} {
      allow read: if isAdmin() || resource.data.status != 'draft';
      allow create, update, delete: if isAdmin();
    }

    /* Authoritative lot data: writes admin-only; reads for signed-in bidders/live UI.
       Critical fields (status, approvals, winner) are only set by Cloud Functions. */
    match /lots/{lotId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();

      /* Bids subcollection — writes only via Cloud Functions. */
      match /bids/{bidId} {
        allow read: if isSignedIn();
        allow create, update, delete: if false;
      }
    }

    /* Safe catalog mirror of lots — synced by Cloud Function only. */
    match /public_lots/{lotId} {
      allow read: if true;
      allow write: if false;
    }

    /* Auction analytics (append-only). Clients may only create `auction_viewed` for self. */
    match /analytics_events/{eventId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.eventType == 'auction_viewed'
        && request.resource.data.lotId is string
        && request.resource.data.lotId.size() > 0
        && request.resource.data.keys().hasAll(['eventType', 'userId', 'lotId', 'timestamp'])
        && request.resource.data.size() == 4;
      allow update, delete: if false;
    }

    match /auction_participants/{docId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.auctionId is string
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    match /lot_permissions/{docId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /deposits/{docId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      // One document per user per lot: ID must be `{uid}_{lotId}` (same as Cloud Function).
      allow create: if isSignedIn()
        && docId == request.auth.uid + '_' + request.resource.data.lotId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.paymentStatus == 'pending'
        && request.resource.data.auctionId is string
        && request.resource.data.lotId is string;
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /bids/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /auction_logs/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    /* User requests to include a property in an auction (admin reviews). */
    match /auction_requests/{requestId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.propertyType is string
        && request.resource.data.governorate is string
        && request.resource.data.area is string
        && request.resource.data.governorateCode is string
        && request.resource.data.areaCode is string
        && request.resource.data.governorateAr is string
        && request.resource.data.governorateEn is string
        && request.resource.data.areaAr is string
        && request.resource.data.areaEn is string
        && request.resource.data.price is number
        && request.resource.data.size is number
        && request.resource.data.roomCount is int
        && request.resource.data.masterRoomCount is int
        && request.resource.data.bathroomCount is int
        && request.resource.data.parkingCount is int
        && request.resource.data.hasElevator is bool
        && request.resource.data.hasCentralAC is bool
        && request.resource.data.hasSplitAC is bool
        && request.resource.data.hasMaidRoom is bool
        && request.resource.data.hasDriverRoom is bool
        && request.resource.data.hasLaundryRoom is bool
        && request.resource.data.hasGarden is bool
        && request.resource.data.description is string
        && request.resource.data.images is list
        && request.resource.data.acceptLowerStartPrice is bool
        && request.resource.data.auctionFee is number
        && request.resource.data.auctionFee >= 1
        && request.resource.data.auctionFee <= 1000000
        && request.resource.data.auctionFeeStatus == 'pending'
        && !request.resource.data.keys().hasAny(['auctionFeePaidAt', 'paymentReference']);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /* ============================================================
        Company payments ledger (manual cash / bank / check — admin only)
    ============================================================ */

    /// Bank/check: document ID must equal referenceNumber (unique key). Cash: auto ID, no stored reference.
    function companyPaymentCreateValid(paymentId) {
      let d = request.resource.data;
      return d.amount is number
        && d.amount > 0
        && d.status in ['pending', 'confirmed', 'rejected']
        && d.type in ['auction_fee', 'commission', 'other']
        && d.reason in ['sale', 'rent', 'auction', 'management_fee', 'other']
        && d.source in ['bank_transfer', 'certified_check', 'cash']
        && d.relatedType in ['auction_request', 'deal', 'manual']
        && d.notes is string
        && d.createdBy == request.auth.uid
        && d.updatedBy == request.auth.uid
        && d.updatedBy is string
        && d.createdAt is timestamp
        && (!('relatedId' in d) || d.relatedId is string)
        && (
          (d.source in ['bank_transfer', 'certified_check']
            && paymentId == d.referenceNumber
            && d.referenceNumber is string
            && d.referenceNumber.size() > 0)
          || (d.source == 'cash'
            && (!('referenceNumber' in d)
              || (d.referenceNumber is string && d.referenceNumber.size() == 0)))
        )
        && (
          (d.type == 'auction_fee'
            && d.relatedType == 'auction_request'
            && d.relatedId is string
            && d.relatedId.size() > 0)
          || (d.type == 'commission'
            && d.relatedType == 'deal'
            && d.relatedId is string
            && d.relatedId.size() > 0)
          || (d.type == 'other'
            && d.relatedType == 'manual')
        )
        && (!(d.type == 'commission' && d.relatedType == 'deal' && d.status == 'confirmed')
            || dealExistsAndCommissionFinalized(d.relatedId));
    }

    function companyPaymentRelatedIdUnchanged() {
      return (!('relatedId' in resource.data) && !('relatedId' in request.resource.data))
        || ('relatedId' in resource.data && 'relatedId' in request.resource.data
            && resource.data.relatedId == request.resource.data.relatedId);
    }

    function companyPaymentReferenceNumberUnchanged() {
      return (!('referenceNumber' in resource.data) && !('referenceNumber' in request.resource.data))
        || ('referenceNumber' in resource.data && 'referenceNumber' in request.resource.data
            && resource.data.referenceNumber == request.resource.data.referenceNumber);
    }

    /// When confirming a commission linked to a deal, deal must exist and be finalized.
    function companyPaymentCommissionConfirmDealFinal() {
      let r = resource.data;
      let n = request.resource.data;
      return !(r.type == 'commission' && r.relatedType == 'deal'
          && r.status != 'confirmed' && n.status == 'confirmed')
        || ('relatedId' in r
            && r.relatedId is string
            && dealExistsAndCommissionFinalized(r.relatedId));
    }

    /// Updates may only change status, notes, and updatedBy; all financial / linkage fields stay fixed.
    function companyPaymentUpdateValid() {
      let r = resource.data;
      let n = request.resource.data;
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'notes', 'updatedBy'])
        && r.amount == n.amount
        && r.type == n.type
        && r.reason == n.reason
        && r.source == n.source
        && r.relatedType == n.relatedType
        && r.createdAt == n.createdAt
        && r.createdBy == n.createdBy
        && companyPaymentRelatedIdUnchanged()
        && companyPaymentReferenceNumberUnchanged()
        && n.status in ['pending', 'confirmed', 'rejected']
        && n.notes is string
        && n.updatedBy is string
        && n.updatedBy == request.auth.uid
        && companyPaymentCommissionConfirmDealFinal();
    }

    match /company_payments/{paymentId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && companyPaymentCreateValid(paymentId);
      allow update: if isAdmin() && companyPaymentUpdateValid();
      // No deletes — financial audit trail. Void entries via status = "rejected".
      allow delete: if false;
    }

    /* Idempotency keys for addCompanyPaymentAdmin (Admin SDK / Cloud Functions only). */
    match /company_payment_idempotency/{keyId} {
      allow read, write: if false;
    }

    /* ============================================================
        Payment audit logs (append-only; mirrors company_payments events)
    ============================================================ */

    match /payment_logs/{logId} {
      allow read: if isAdmin();
      // Only Cloud Functions (Admin SDK) may create logs — unified audit source.
      allow create: if false;
      allow update, delete: if false;
    }

    /* ============================================================
        Invoices (PDF receipts — created only by Cloud Functions)
    ============================================================ */

    match /invoices/{invoiceId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    /* ============================================================
        Financial ledger (revenue — written only by Cloud Functions)
    ============================================================ */

    match /financial_ledger/{entryId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    /* ============================================================
        System counters (invoice sequences — Functions / Admin SDK only)
    ============================================================ */

    match /system/{docId} {
      allow read, write: if false;
    }

    /* AI callable rate counters — Admin SDK / Cloud Functions only */
    match /ai_call_rate_limits/{uid} {
      allow read, write: if false;
    }

    /* ============================================================
        Interested Leads (تفاصيل المهتم — ضغط "أنا مهتم")
    ============================================================ */

    match /interested_leads/{docId} {

      // Deprecated — leads live on `deals` (`interestSource` + `leadSource: interested_button`).
      allow create: if false;

      // 👀 الأدمن يقرأ السجلات القديمة فقط
      allow read: if isAdmin();

      allow update: if false;

      allow delete: if isAdmin();
    }
  }
}
