{
  "name": "functions",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "migrate:auction": "npx ts-node --transpile-only scripts/migrateAuctionSchema.ts",
    "migrate:auction:dry-run": "npx ts-node --transpile-only scripts/migrateAuctionSchema.ts --dry-run",
    "cleanup:property-status": "FIREBASE_PROJECT_ID=aqarai-caf5d node scripts/propertyStatusCleanup.mjs",
    "cleanup:property-status:dry-run": "FIREBASE_PROJECT_ID=aqarai-caf5d node scripts/propertyStatusCleanup.mjs --dry-run"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@sparticuz/chromium": "^141.0.0",
    "@types/graphql": "^14.2.3",
    "arabic-reshaper": "^1.1.0",
    "bidi-js": "^1.0.3",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "graphql": "^16.12.0",
    "nodemailer": "^8.0.4",
    "openai": "^4.104.0",
    "puppeteer-core": "^24.40.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.11",
    "firebase-functions-test": "^3.4.1",
    "typescript": "^5.7.3"
  },
  "private": true
}
