rules_version = '2';

// Public read for Instagram-ready outputs (uploads are server-only via Admin SDK).
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // iOS sometimes sends null or octet-stream; listing uploads set image/jpeg from the client.
    function isLikelyListingImageUpload() {
      return request.resource.contentType == null
        || request.resource.contentType.matches('image/.*')
        || request.resource.contentType == 'application/octet-stream'
        || request.resource.contentType == 'binary/octet-stream';
    }

    // Preferred: uploader uid is in the path — avoids Storage→Firestore get() edge cases (unauthorized).
    match /users/{userId}/property_images/{propertyId}/{imageFile} {
      allow read: if true;

      allow write: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.size < 12 * 1024 * 1024
        && request.resource.size > 0
        && isLikelyListingImageUpload();

      allow delete: if isAdmin()
        || (isSignedIn() && request.auth.uid == userId);
    }

    match /auction_request_images/{userId}/{requestId}/{imageFile} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow write: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.size < 12 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // Legacy listing photos (older app builds). New uploads use users/{uid}/property_images/...
    match /properties/{propertyId}/{imageFile} {
      allow read: if true;

      function propertyOwnedByCaller() {
        return firestore.get(/databases/(default)/documents/properties/$(propertyId)).data.ownerId
            == request.auth.uid;
      }

      allow write: if isSignedIn()
        && propertyOwnedByCaller()
        && request.resource.size < 12 * 1024 * 1024
        && request.resource.size > 0
        && isLikelyListingImageUpload();

      allow delete: if isAdmin()
        || (isSignedIn() && propertyOwnedByCaller());
    }

    match /generated_posts/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Template is read by Cloud Functions service account only (bypasses rules).
    match /templates/{allPaths=**} {
      allow read, write: if false;
    }

    // Invoice PDFs (uploaded by Cloud Functions Admin SDK; admin app reads via SDK).
    match /invoices/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
